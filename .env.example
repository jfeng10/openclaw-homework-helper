GEMINI_API_KEY=replace-with-your-gemini-api-key
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
LOG_LEVEL=INFO

# Optional: keep generated SQLite data outside the repository.
# HOMEWORK_DB_PATH=/absolute/path/outside/repo/homework.db

# Optional: set a private random value to create stable pseudonymous Telegram user IDs.
# USER_ID_SALT=replace-with-a-long-random-private-value
